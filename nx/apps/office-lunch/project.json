{
  "name": "office-lunch",
  "projectType": "application",
  "sourceRoot": "apps/office-lunch/src",
  "tags": ["scope:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "options": {
        "outputPath": "dist/office-lunch",
        "index": "apps/office-lunch/src/index.html",
        "browser": "apps/office-lunch/src/main.ts",
        "tsConfig": "apps/office-lunch/tsconfig.app.json",
        "assets": [{ "glob": "**/*", "input": "apps/office-lunch/public" }],
        "styles": ["apps/office-lunch/src/styles.scss"],
        "scripts": []
      }
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "options": { "buildTarget": "office-lunch:build" }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["apps/office-lunch/**/*.ts"] }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest --run --config apps/office-lunch/vitest.config.ts", "cwd": "{workspaceRoot}" }
    }
  }
}
