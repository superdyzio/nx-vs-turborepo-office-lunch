{
  "name": "util",
  "projectType": "library",
  "sourceRoot": "libs/util/src",
  "tags": ["scope:util"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["libs/util/**/*.ts"] }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest --run --config libs/util/vitest.config.ts", "cwd": "{workspaceRoot}" }
    }
  }
}
